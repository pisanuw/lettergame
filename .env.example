# Copy this file to .env and fill in your values.
# In production, set these as environment variables in Netlify:
#   Site settings -> Environment variables

# Google Custom Search API key (console.cloud.google.com)
GOOGLE_API_KEY=your_google_api_key_here

# Google Custom Search Engine ID (programmablesearchengine.google.com)
GOOGLE_CX=your_search_engine_id_here

# GitHub personal access token with repo write access (github.com/settings/tokens)
# Needed by admin.html and suggest-word function to commit new words to the repository
GITHUB_TOKEN=your_github_token_here

# Admin page passwords (admin.html)
# ADMIN_PASSWORD_BASIC: add words directly, no verification
# ADMIN_PASSWORD_VERIFIED: add words with Wikipedia verification before each commit
ADMIN_PASSWORD_BASIC=your_basic_admin_password_here
ADMIN_PASSWORD_VERIFIED=your_verified_admin_password_here

# SMTP settings for emailing admin when a suggested word fails Wikipedia verification.
# Provider example: Resend (smtp.resend.com). Leave HOST empty to disable email.
AUTH_SMTP_HOST=
AUTH_SMTP_PORT=587
AUTH_SMTP_USER=
AUTH_SMTP_PASS=
AUTH_SMTP_FROM=noreply@example.com

# Admin email address for word suggestion notifications
ADMIN_EMAIL=admin@example.com
